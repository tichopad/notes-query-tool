{
	"name": "notes-query-tool",
	"module": "src/main.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"db:delete-stale-lock": "rm ./dbdata/postmaster.pid",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "bun scripts/migrate.ts",
		"db:query": "bun scripts/query.ts",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"testdata:load": "bun dev load --glob 'testdata/**/*.md'",
		"testdata:reindex": "rm -rf dbdata && bun run db:migrate && bun run testdata:load",
		"dev": "bun run src/main.ts",
		"test": "node --test --test-reporter=spec 'src/**/*.test.ts' 'bench/**/*.test.ts'",
		"check": "biome check . && tsc --noEmit && bun run test",
		"fix": "biome check --write ."
	},
	"dependencies": {
		"@electric-sql/pglite": "0.4.4",
		"@huggingface/transformers": "4.1.0",
		"citty": "0.2.2",
		"drizzle-orm": "0.45.2",
		"marked": "18.0.1",
		"yaml": "2.8.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@types/bun": "1.3.12",
		"drizzle-kit": "0.31.10",
		"typescript": "6.0.2"
	},
	"patchedDependencies": {
		"drizzle-kit@0.31.10": "patches/drizzle-kit@0.31.10.patch"
	}
}
